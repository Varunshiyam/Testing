<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Late_Registration</fullName>
    <active>true</active>
    <errorConditionFormula>Registration_Date__c &gt;= Event__r.Date__c</errorConditionFormula>
    <errorMessage>&quot;Registration date must be before the event date.&quot;</errorMessage>
</ValidationRule>
